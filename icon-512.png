:root{
    --bg:#f3f4f6;
    --card:#ffffff;
    --text:#17212b;
    --muted:#667085;
    --line:#d0d5dd;
    --brand:#b42318;
    --brand-dark:#7a271a;
    --ok:#16a34a;
    --blue:#175cd3;
    --warn:#f59e0b;
    --danger:#dc2626;
    --relief:#7c3aed;
    --neutral:#98a2b3;
    --ink:#0f172a;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:Arial,Helvetica,sans-serif;background:var(--bg);color:var(--text)}
  header{background:#1f2937;color:#fff;padding:18px 24px;display:flex;gap:18px;align-items:center;justify-content:space-between;flex-wrap:wrap}
  header h1{font-size:22px;margin:0}
  header p{margin:4px 0 0;color:#d1d5db;font-size:13px}
  .container{max-width:1600px;margin:0 auto;padding:20px}
  .toolbar,.form-grid,.stats{display:grid;gap:12px}
  .toolbar{grid-template-columns:repeat(8,minmax(120px,1fr));margin-bottom:16px}
  .stats{grid-template-columns:repeat(4,1fr);margin-bottom:16px}
  .stat,.panel{background:var(--card);border:1px solid var(--line);border-radius:12px;box-shadow:0 1px 3px rgba(16,24,40,.08)}
  .stat{padding:14px}
  .stat .label{font-size:12px;color:var(--muted)}
  .stat .value{font-size:26px;font-weight:700;margin-top:4px}
  .panel{padding:16px;margin-bottom:16px}
  .panel h2{font-size:17px;margin:0 0 12px}
  label{font-size:12px;color:var(--muted);display:block;margin-bottom:5px}
  input,select,textarea,button{font:inherit}
  input,select,textarea{width:100%;padding:9px 10px;border:1px solid var(--line);border-radius:8px;background:#fff}
  textarea{min-height:74px;resize:vertical}
  button{border:0;border-radius:8px;padding:10px 12px;cursor:pointer;font-weight:700}
  .btn-primary{background:var(--brand);color:#fff}
  .btn-secondary{background:#344054;color:#fff}
  .btn-light{background:#eaecf0;color:#344054}
  .btn-danger{background:#fee4e2;color:#b42318}
  .btn-outline{background:#fff;border:1px solid var(--line);color:#344054}
  .form-grid{grid-template-columns:repeat(6,1fr)}
  .span-2{grid-column:span 2}
  .span-3{grid-column:span 3}
  .span-6{grid-column:span 6}
  .small{font-size:12px;color:var(--muted)}
  .table-wrap{overflow:auto}
  table{width:100%;border-collapse:collapse;min-width:1450px}
  th,td{padding:9px 8px;border-bottom:1px solid #eaecf0;text-align:left;font-size:13px;vertical-align:top}
  th{background:#f9fafb;color:#475467;position:sticky;top:0;z-index:1}
  tr.flag-warn{background:#fffbeb}
  tr.flag-danger{background:#fef2f2}
  .badge{display:inline-block;padding:4px 8px;border-radius:999px;font-size:11px;font-weight:700}
  .badge-ok{background:#dcfce7;color:#166534}
  .badge-warn{background:#fef3c7;color:#92400e}
  .badge-danger{background:#fee2e2;color:#991b1b}
  .badge-info{background:#dbeafe;color:#1d4ed8}
  .badge-neutral{background:#e5e7eb;color:#374151}
  .actions{display:flex;gap:5px;flex-wrap:wrap}
  .actions button{padding:6px 8px;font-size:12px}
  .empty{padding:30px;text-align:center;color:var(--muted)}
  .map-layout{display:grid;grid-template-columns:1.25fr .75fr;gap:16px;align-items:start}
  .map-wrap{background:#f8fafc;border:1px solid var(--line);border-radius:12px;padding:12px}
  .map-illustration{width:100%;height:auto;display:block;border-radius:10px;border:1px solid #d0d5dd;background:#fff}

  .map-image-wrap{position:relative;width:100%;aspect-ratio:964/823;min-height:360px;overflow:hidden}
  .map-image-wrap .map-illustration{position:absolute;inset:0;width:100%;height:100%;object-fit:contain}
  .map-image-wrap .map-overlay{position:absolute;inset:0;width:100%;height:100%;display:block}
  .ipad-post-list{display:none;margin-top:10px;border-top:1px solid var(--line);padding-top:10px}
  .ipad-post-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:6px}
  .ipad-post-btn{min-height:40px;padding:7px 8px;background:#fff;border:1px solid var(--line);color:#344054;font-size:11px;text-align:left}
  .ipad-post-btn.active{border-color:#111827;background:#f3f4f6;font-weight:700}
  @media (max-width:1100px){
    .ipad-post-list{display:block}
    .ipad-post-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .map-image-wrap{min-height:420px}
  }
  @media (max-width:640px){
    .ipad-post-grid{grid-template-columns:1fr 1fr}
    .map-image-wrap{min-height:330px}
  }
  .map-overlay{position:absolute;inset:0;width:100%;height:100%;pointer-events:auto}
  .map-overlay .click-area{cursor:pointer}
  .map-overlay .summary-pill{filter:drop-shadow(0 2px 4px rgba(0,0,0,.18))}
  .map-overlay text{font-family:Arial,Helvetica,sans-serif}

  .map-overlay .post-label-box{fill:rgba(255,255,255,0.92);stroke:#cbd5e1;stroke-width:1.5}
  .map-overlay .post-label-box.selected{stroke:#111827;stroke-width:2.5}
  .map-overlay .post-label-text{font-size:11px;font-weight:700;fill:#0f172a}
  .area-filter-buttons{display:flex;gap:8px;flex-wrap:wrap;margin:0 0 10px}
  .area-filter-btn{border:1px solid var(--line);background:#fff;color:#344054;padding:8px 10px;border-radius:10px;font-size:12px;line-height:1.2;cursor:pointer}
  .area-filter-btn strong{display:block;font-size:13px;margin-bottom:2px}
  .area-filter-btn span{font-size:11px;color:#667085}
  .area-filter-btn.active{border-color:#111827;box-shadow:inset 0 0 0 1px #111827;background:#f8fafc}
  .task-panel{margin-top:12px;border:1px solid var(--line);border-radius:10px;background:#fff;padding:12px}
  .task-panel h3{margin:0 0 6px;font-size:15px}
  .task-meta{font-size:12px;color:var(--muted);margin-bottom:8px}
  .task-chips{display:flex;gap:6px;flex-wrap:wrap}
  .task-chip{display:inline-flex;align-items:center;padding:5px 8px;border-radius:999px;background:#eef2f6;border:1px solid #d0d5dd;font-size:11px;color:#344054}
  .task-empty{font-size:12px;color:var(--muted)}
  .planning-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:12px}
  .planning-card{border:1px solid var(--line);border-radius:10px;background:#fff;padding:12px}
  .planning-card .value{font-size:22px;font-weight:700;margin-top:4px}
  .relief-chain{display:flex;gap:6px;flex-wrap:wrap;margin-top:6px}
  .relief-step{padding:5px 8px;border-radius:999px;background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd;font-size:11px}
  .warning-box{padding:9px 10px;border-radius:8px;background:#fffbeb;border:1px solid #fde68a;color:#92400e;font-size:12px;margin-top:8px}
  .log-list{max-height:220px;overflow:auto;font-size:12px}
  .log-item{padding:7px 0;border-bottom:1px solid #eaecf0}
  .small-select{padding:6px 8px;font-size:12px}
  @media (max-width:1100px){.planning-grid{grid-template-columns:repeat(2,1fr)}}

  .map-overlay .leader-line{stroke:#94a3b8;stroke-width:1.6;fill:none}


  .map-tools{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px}
  .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}
  .legend-item{display:flex;align-items:center;gap:6px;font-size:12px;color:#475467}
  .dot{width:13px;height:13px;border-radius:50%;display:inline-block;border:2px solid rgba(0,0,0,.15)}
  .map-svg{width:100%;height:auto;display:block;border-radius:10px}
  .area-card-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .area-card{border:1px solid var(--line);border-radius:10px;padding:12px;background:#fff}
  .area-card h3{margin:0 0 8px;font-size:14px}
  .area-card p{margin:0;font-size:12px;line-height:1.45;color:#344054}
  .map-caption{font-size:12px;color:var(--muted);margin-bottom:10px}
  footer{padding:8px 20px 24px;color:var(--muted);font-size:12px;text-align:center}

  .timeline-wrap{overflow-x:auto;border:1px solid var(--line);border-radius:10px;background:#fff}
  .timeline-head,.timeline-row{display:grid;grid-template-columns:190px minmax(900px,1fr);align-items:center}
  .timeline-head{position:sticky;top:0;background:#f9fafb;border-bottom:1px solid var(--line);z-index:3}
  .timeline-label{padding:10px;border-right:1px solid var(--line);font-size:12px}
  .timeline-grid{position:relative;min-width:900px;height:46px;background:
    repeating-linear-gradient(to right,#eef2f7 0,#eef2f7 1px,transparent 1px,transparent calc(100% / 12));}
  .timeline-hours{position:relative;min-width:900px;height:34px}
  .timeline-hour{position:absolute;top:8px;transform:translateX(-50%);font-size:11px;color:#475467}
  .timeline-row{border-bottom:1px solid #eef2f7}
  .timeline-row:last-child{border-bottom:0}
  .timeline-unit{padding:10px;border-right:1px solid var(--line);font-size:12px}
  .timeline-unit strong{display:block;font-size:13px}
  .timeline-bar{position:absolute;top:9px;height:28px;border-radius:8px;display:flex;align-items:center;padding:0 8px;color:#fff;font-size:11px;font-weight:700;white-space:nowrap;overflow:hidden;min-width:6px}
  .timeline-bar.active{background:#16a34a}
  .timeline-bar.warning{background:#f59e0b}
  .timeline-bar.danger{background:#dc2626}
  .timeline-bar.travel{background:#175cd3}
  .timeline-bar.relief{background:#7c3aed}
  .timeline-bar.finished{background:#98a2b3}
  .timeline-now{position:absolute;top:0;bottom:0;width:2px;background:#111827;z-index:2}
  .timeline-now::before{content:"nu";position:absolute;top:-17px;left:50%;transform:translateX(-50%);font-size:10px;font-weight:700;color:#111827}
  .timeline-legend{display:flex;gap:12px;flex-wrap:wrap;margin:8px 0 0}
  .timeline-empty{padding:24px;text-align:center;color:var(--muted)}


  .timeline-edit-btn{margin-top:6px;padding:5px 7px;font-size:11px;background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd}
  .modal-backdrop{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;z-index:9999;padding:20px}
  .modal-backdrop.open{display:flex}
  .modal-card{background:#fff;width:min(680px,100%);max-height:90vh;overflow:auto;border-radius:14px;box-shadow:0 20px 60px rgba(0,0,0,.28);padding:18px}
  .modal-card h3{margin:0 0 14px;font-size:18px}
  .modal-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}
  .modal-actions{display:flex;justify-content:flex-end;gap:8px;margin-top:16px}
  @media (max-width:700px){.modal-grid{grid-template-columns:1fr}}

  @media (max-width:1100px){
    .toolbar,.form-grid,.stats,.map-layout,.area-card-grid{grid-template-columns:repeat(2,1fr)}
    .span-2,.span-3,.span-6{grid-column:span 2}
  }

  html{-webkit-text-size-adjust:100%;text-size-adjust:100%}
  body{min-height:100vh;min-height:100dvh;padding-bottom:env(safe-area-inset-bottom)}
  header{padding-top:calc(18px + env(safe-area-inset-top));padding-left:calc(24px + env(safe-area-inset-left));padding-right:calc(24px + env(safe-area-inset-right))}
  button,input,select,textarea{min-height:44px}
  input,select,textarea{font-size:16px}
  .toolbar button,.form-grid button,.modal-actions button{touch-action:manipulation}
  .map-image-wrap{touch-action:manipulation}
  .mobile-tabs{display:none}
  .mobile-card-list{display:none}
  .scroll-hint{display:none;font-size:11px;color:var(--muted);margin:6px 0}
  .sticky-mobile-actions{display:none}
  .timeline-wrap,.table-wrap{-webkit-overflow-scrolling:touch}
  .panel-anchor{scroll-margin-top:12px}
  @media (max-width:900px){
    .container{padding:12px}
    header{padding:14px 14px calc(14px + env(safe-area-inset-bottom));align-items:flex-start}
    header h1{font-size:19px} header p,#clock{font-size:12px}
    .toolbar{grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .stats{grid-template-columns:repeat(2,minmax(0,1fr));gap:8px}
    .stat{padding:10px}.stat .value{font-size:22px}
    .panel{padding:12px;border-radius:10px}.panel h2{font-size:16px}
    .map-layout,.area-card-grid{grid-template-columns:1fr}
    .planning-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .form-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .span-2,.span-3,.span-6{grid-column:span 2}
    .timeline-head,.timeline-row{grid-template-columns:150px minmax(900px,1fr)}
    .timeline-label,.timeline-unit{padding:8px}
    .modal-card{padding:14px}.modal-grid{grid-template-columns:1fr}
    .mobile-tabs{display:flex;position:sticky;top:0;z-index:50;background:rgba(243,244,246,.96);backdrop-filter:blur(8px);padding:8px 0;gap:6px;overflow-x:auto;-webkit-overflow-scrolling:touch}
    .mobile-tabs button{min-width:max-content;padding:8px 10px;background:#fff;border:1px solid var(--line);color:#344054;font-size:12px}
    .scroll-hint{display:block}
    .sticky-mobile-actions{display:flex;position:fixed;left:0;right:0;bottom:0;z-index:100;background:rgba(255,255,255,.96);backdrop-filter:blur(10px);padding:8px calc(8px + env(safe-area-inset-right)) calc(8px + env(safe-area-inset-bottom)) calc(8px + env(safe-area-inset-left));gap:8px;border-top:1px solid var(--line)}
    .sticky-mobile-actions button{flex:1}
    footer{padding-bottom:calc(84px + env(safe-area-inset-bottom))}
  }
  @media (max-width:640px){
    .container{padding:8px}.toolbar{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,minmax(0,1fr))}
    .form-grid{grid-template-columns:1fr}.span-2,.span-3,.span-6{grid-column:span 1}
    .planning-grid{grid-template-columns:1fr 1fr}.area-filter-buttons{display:grid;grid-template-columns:repeat(2,minmax(0,1fr))}
    .area-filter-btn{width:100%}.map-caption{font-size:11px}.map-illustration{border-radius:8px}.legend{gap:6px}.legend-item{font-size:10px}
    .timeline-head,.timeline-row{grid-template-columns:125px minmax(860px,1fr)}.timeline-unit{font-size:11px}.timeline-unit strong{font-size:12px}
    .table-wrap{display:none}.mobile-card-list{display:block}
    .unit-card{border:1px solid var(--line);border-radius:10px;background:#fff;padding:10px;margin-bottom:8px}
    .unit-card.flag-warn{background:#fffbeb}.unit-card.flag-danger{background:#fef2f2}
    .unit-card-head{display:flex;justify-content:space-between;gap:8px;align-items:flex-start}
    .unit-card-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:8px}.unit-card-grid div{font-size:12px}
    .unit-card-grid strong{display:block;color:#475467;font-size:10px;text-transform:uppercase;letter-spacing:.03em}
    .unit-card .actions{margin-top:10px}.unit-card .actions button{flex:1}
    .modal-backdrop{align-items:flex-end;padding:0}.modal-card{width:100%;max-height:92dvh;border-radius:16px 16px 0 0;padding-bottom:calc(18px + env(safe-area-inset-bottom))}
    .planning-card .value{font-size:20px}.task-chips{gap:4px}.task-chip{font-size:10px;padding:4px 7px}
  }
  @media (min-width:901px) and (max-width:1280px){
    .container{max-width:100%;padding:16px}.toolbar{grid-template-columns:repeat(4,minmax(0,1fr))}
    .form-grid{grid-template-columns:repeat(3,minmax(0,1fr))}.span-6,.span-3{grid-column:span 3}.span-2{grid-column:span 2}
    .map-layout{grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr)}
  }
  @media (hover:none) and (pointer:coarse){button:hover{filter:none}.click-area{cursor:default}}


  .app-shell{display:grid;grid-template-columns:minmax(0,1.25fr) minmax(360px,.75fr);gap:16px;align-items:start}
  .app-main,.app-side{min-width:0}
  .wizard{border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}
  .wizard-progress{display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid var(--line);background:#f9fafb}
  .wizard-progress button{border-radius:0;background:transparent;color:#667085;border-right:1px solid var(--line);padding:12px 8px;font-size:12px}
  .wizard-progress button:last-child{border-right:0}
  .wizard-progress button.active{background:#1f2937;color:#fff}
  .wizard-progress button.done{background:#dcfae6;color:#067647}
  .wizard-step{display:none;padding:16px}
  .wizard-step.active{display:block}
  .wizard-step h3{margin:0 0 4px;font-size:17px}
  .wizard-step-intro{font-size:12px;color:var(--muted);margin-bottom:14px}
  .wizard-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
  .wizard-full{grid-column:1/-1}
  .wizard-actions{display:flex;justify-content:space-between;gap:8px;margin-top:16px}
  .wizard-actions .right{display:flex;gap:8px;margin-left:auto}
  .relief-toggle{display:flex;gap:10px;align-items:center;padding:12px;border:1px solid var(--line);border-radius:10px;background:#f9fafb}
  .relief-toggle input{width:22px;height:22px;min-height:22px}
  .review-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
  .review-item{border:1px solid var(--line);border-radius:9px;padding:10px;background:#f9fafb}
  .review-item strong{display:block;font-size:11px;text-transform:uppercase;color:#667085;margin-bottom:4px}
  .review-item span{font-size:14px}
  .source-choice{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}
  .source-choice label{display:flex;align-items:flex-start;gap:8px;padding:10px;border:1px solid var(--line);border-radius:10px;background:#f9fafb;cursor:pointer}
  .source-choice input{width:20px;height:20px;min-height:20px;margin-top:1px}
  .source-choice label.selected{border-color:#111827;background:#eef2f7}
  .source-badge{display:inline-flex;align-items:center;padding:3px 7px;border-radius:999px;font-size:10px;font-weight:700}
  .source-vggm{background:#dcfce7;color:#166534}
  .source-vr{background:#dbeafe;color:#1d4ed8}
  .source-other{background:#e5e7eb;color:#374151}
  @media (max-width:700px){.source-choice{grid-template-columns:1fr}}
  .adaptive-dashboard{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
  .adaptive-card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:12px}
  .adaptive-card .value{font-size:24px;font-weight:700}
  .adaptive-card .label{font-size:11px;color:var(--muted)}
  .compact-map .map-layout{grid-template-columns:1fr}
  .compact-map .area-card{display:none}
  .compact-map .map-image-wrap{min-height:420px}
  @media (min-width:1200px){
    .entry-panel{position:sticky;top:12px}
  }
  @media (max-width:1100px){
    .app-shell{grid-template-columns:1fr}
    .app-side{order:-1}
    .wizard-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    .adaptive-dashboard{grid-template-columns:repeat(4,1fr)}
    .entry-panel{position:static}
  }
  @media (max-width:700px){
    .wizard-progress{grid-template-columns:repeat(4,minmax(76px,1fr));overflow-x:auto}
    .wizard-progress button{font-size:11px;padding:10px 6px}
    .wizard-step{padding:12px}
    .wizard-grid,.review-grid{grid-template-columns:1fr}
    .adaptive-dashboard{grid-template-columns:repeat(2,1fr)}
    .wizard-actions{position:sticky;bottom:0;background:#fff;padding-top:10px}
  }

  @media print{
    body{background:#fff}
    header{background:#fff;color:#000;padding:0 0 12px}
    header p{color:#444}
    .toolbar,.entry-panel,.actions,.map-tools,footer{display:none!important}
    .container{max-width:none;padding:0}
    .panel,.stat{box-shadow:none;border:1px solid #999}
    .map-layout{grid-template-columns:1fr}
    table{min-width:0;font-size:10px}
    th,td{font-size:10px;padding:5px}
  }